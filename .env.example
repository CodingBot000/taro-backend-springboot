# Spring Boot runtime
PORT=8080
APP_VERSION=local-dev
RATE_LIMIT_REQUESTS_PER_MINUTE=10
REQUEST_SOURCE_VALIDATION_ENABLED=true
SPRING_PROFILES_ACTIVE=postgres

# Frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100,https://heartsignal.cloud,https://www.heartsignal.cloud,https://taro.heartsignal.cloud,https://taro-ai-mu.vercel.app
# Example for Vercel preview/production domains:
# CORS_ALLOWED_ORIGIN_PATTERNS=https://your-project-*.vercel.app,https://your-custom-domain.com
CORS_ALLOWED_ORIGIN_PATTERNS=

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=taro
DB_USER=taro
DB_PASSWORD=change_me_before_production
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false

# Google OAuth / JWT auth
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_REDIRECT_URI=https://api.heartsignal.cloud/login/oauth2/code/google
FRONTEND_BASE_URL=https://taro-ai-mu.vercel.app
JWT_SECRET=replace_me_with_a_base64_secret
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=1800
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=None

# Hugging Face / Gradio
HF_SPACE_URL=AutoBot000/tarot-reading
HF_TOKEN=hf_replace_me
HF_API_PREFIX=/gradio_api
HF_CONNECT_TIMEOUT=5s
HF_READ_TIMEOUT=130s
HF_GENERATE_READING_API_NAME=generate_reading
HF_BACKEND_VERSION_API_NAME=backend_version

# Docker / compose helpers
HOST_PORT=8080
DOCKER_IMAGE_NAME=taro-spring-service:local
TZ=Asia/Seoul
JAVA_OPTS=-Xms256m -Xmx512m
